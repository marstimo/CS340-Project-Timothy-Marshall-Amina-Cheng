<!-- ManaVault Inventory Manager - CS340 Portfolio Project -->

<h1>Order Items</h1>

<table>
    <thead>
        <tr>
            {{#each orderItems.[0]}}
            <th>{{@key}}</th>
            {{/each}}
            <th>Delete</th>
        </tr>
    </thead>
    <tbody>
        {{#each orderItems}}
        <tr>
            <td>{{this.[Order Item ID]}}</td>
            <td>{{this.[Order]}}</td>
            <td>{{this.[Product]}}</td>
            <td>{{this.[Unit Price]}}</td>
            <td>{{this.[Quantity]}}</td>
            <td>{{this.[Amount]}}</td>
            <td>
                <form method="POST" action="/orderItems/delete"
                    onsubmit="return confirm('Are you sure you want to delete this order item?');">
                    <input type="hidden" name="delete_order_item_id" value="{{this.[Order Item ID]}}">
                    <button type="submit">Delete</button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<section class="formSection">
    <h2>Add an Order Item</h2>
    <form class="cuForm" method="POST" action="/orderItems/create">
        <label for="create_order_item_order_id">Order</label>
        <select name="create_order_item_order_id" id="create_order_item_order_id" required>
            <option value="" disabled selected>Select an Order</option>
            {{#each orderOptions}}
            <option value="{{this.orderID}}">{{this.orderLabel}}</option>
            {{/each}}
        </select>

        <label for="create_order_item_product_id">Product</label>
        <select name="create_order_item_product_id" id="create_order_item_product_id" required>
            <option value="" disabled selected>Select a Product</option>
            {{#each productOptions}}
            <option value="{{this.productID}}">{{this.productLabel}}</option>
            {{/each}}
        </select>

        <label for="create_order_item_unit_price">Unit Price</label>
        <input type="number" step="0.01" min="0" name="create_order_item_unit_price" id="create_order_item_unit_price" required>

        <label for="create_order_item_quantity">Quantity</label>
        <input type="number" min="1" name="create_order_item_quantity" id="create_order_item_quantity" required>

        <label for="create_order_item_amount">Amount</label>
        <input type="number" step="0.01" min="0" name="create_order_item_amount" id="create_order_item_amount" readonly>

        <input type="submit" value="Add Order Item">
    </form>
</section>

<section class="formSection">
    <h2>Update an Order Item</h2>
    <form class="cuForm" method="POST" action="/orderItems/update">
        <label for="update_order_item_id">Order Item to Update</label>
        <select name="update_order_item_id" id="update_order_item_id" required>
            <option value="" disabled selected>Select an Order Item</option>
            {{#each orderItems}}
            <option value="{{this.[Order Item ID]}}">
                {{this.[Order Item ID]}} - {{this.[Order]}} - {{this.[Product]}}
            </option>
            {{/each}}
        </select>

        <label for="update_order_item_order_id">Order</label>
        <select name="update_order_item_order_id" id="update_order_item_order_id" required>
            <option value="" disabled selected>Select an Order</option>
            {{#each orderOptions}}
            <option value="{{this.orderID}}">{{this.orderLabel}}</option>
            {{/each}}
        </select>

        <label for="update_order_item_product_id">Product</label>
        <select name="update_order_item_product_id" id="update_order_item_product_id" required>
            <option value="" disabled selected>Select a Product</option>
            {{#each productOptions}}
            <option value="{{this.productID}}">{{this.productLabel}}</option>
            {{/each}}
        </select>

        <label for="update_order_item_unit_price">Unit Price</label>
        <input type="number" step="0.01" min="0" name="update_order_item_unit_price" id="update_order_item_unit_price" required>

        <label for="update_order_item_quantity">Quantity</label>
        <input type="number" min="1" name="update_order_item_quantity" id="update_order_item_quantity" required>

        <label for="update_order_item_amount">Amount</label>
        <input type="number" step="0.01" min="0" name="update_order_item_amount" id="update_order_item_amount" readonly>

        <input type="submit" value="Update Order Item">
    </form>
</section>

<script>
window.orderItemData = {{{orderItemRecordsJson}}};
window.productPriceData = {{{productRecordsJson}}};
</script>