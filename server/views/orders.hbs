<h1>Orders</h1>

<table>
    <thead>
        <tr>
            {{#each orders.[0]}}
            <th>{{@key}}</th>
            {{/each}}
            <th>Delete</th>
        </tr>
    </thead>

    <tbody>
        {{#each orders}}
        <tr>
            <td>{{this.[Order ID]}}</td>
            <td>{{this.[Customer ID]}}</td>
            <td>{{this.[Order Number]}}</td>
            <td>{{this.[Order Date]}}</td>
            <td>{{this.[Order Status]}}</td>
            <td>{{this.[Grand Total]}}</td>
            <td>
                <form method='POST' action='/orders/{{this.[Order ID]}}/delete'
                    onsubmit="return confirm('Are you sure you want to delete Order #{{this.[Order ID]}}?');">
                    <button type='submit'>Delete</button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<h2>Add an Order</h2>
<form class='cuForm' id='create_order_form' method='POST' action='/orders/create'>
    <label for='create_order_customer_id'>Customer:</label>
    <select name='create_order_customer_id' id='create_order_customer_id'>
        <option value=''>No Customer</option>
        {{#each customers}}
        <option value='{{this.[Customer ID]}}'>
            {{this.[Customer ID]}} - {{this.[First Name]}} {{this.[Last Name]}}
        </option>
        {{/each}}
    </select>

    <label for='create_order_number'>Order Number:</label>
    <input type='text' name='create_order_number' id='create_order_number' required />

    <label for='create_order_date'>Order Date:</label>
    <input type='datetime-local' name='create_order_date' id='create_order_date' required />

    <label for='create_order_status'>Status:</label>
    <input type='text' name='create_order_status' id='create_order_status' />

    <label for='create_order_grand_total'>Grand Total:</label>
    <input type='number' step='0.01' min='0' name='create_order_grand_total' id='create_order_grand_total' required />

    <input type='submit' value='Add Order' />
</form>

<h2>Update an Order</h2>
<form class='cuForm' id='update_order_form' method='POST' action='/orders/update'>
    <label for='update_order_id'>Order to Update:</label>
    <select name='update_order_id' id='update_order_id' required>
        <option value='' disabled selected>Select an Order</option>
        {{#each orders}}
        <option value='{{this.[Order ID]}}'>
            {{this.[Order ID]}} - {{this.[Order Number]}}
        </option>
        {{/each}}
    </select>

    <label for='update_order_customer_id'>Customer:</label>
    <select name='update_order_customer_id' id='update_order_customer_id'>
        <option value=''>No Customer</option>
        {{#each customers}}
        <option value='{{this.[Customer ID]}}'>
            {{this.[Customer ID]}} - {{this.[First Name]}} {{this.[Last Name]}}
        </option>
        {{/each}}
    </select>

    <label for='update_order_number'>Order Number:</label>
    <input type='text' name='update_order_number' id='update_order_number' required />

    <label for='update_order_date'>Order Date:</label>
    <input type='datetime-local' name='update_order_date' id='update_order_date' required />

    <label for='update_order_status'>Status:</label>
    <input type='text' name='update_order_status' id='update_order_status' />

    <label for='update_order_grand_total'>Grand Total:</label>
    <input type='number' step='0.01' min='0' name='update_order_grand_total' id='update_order_grand_total' required />

    <input type='submit' value='Update Order' />
</form>