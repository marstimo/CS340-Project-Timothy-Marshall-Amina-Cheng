<h1>Products</h1>

<table>
    <thead>
        <tr>
            {{#each products.[0]}}
            <th>{{@key}}</th>
            {{/each}}
            <th>Delete</th>
        </tr>
    </thead>

    <tbody>
        {{#each products}}
        <tr>
            <td>{{this.[Product ID]}}</td>
            <td>{{this.[Product Type]}}</td>
            <td>{{this.[Set ID]}}</td>
            <td>{{this.[Name]}}</td>
            <td>{{this.[Card Condition]}}</td>
            <td>{{this.[SKU]}}</td>
            <td>{{this.[Price]}}</td>
            <td>{{this.[Quantity]}}</td>
            <td>
                <form method='POST' action='/products/{{this.[Product ID]}}/delete'
                    onsubmit="return confirm('Are you sure you want to delete Product #{{this.[Product ID]}}?');">
                    <button type='submit'>Delete</button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>

<h2>Add a Product</h2>
<form class='cuForm' id='create_product_form' method='POST' action='/products/create'>
    <label for='create_product_type'>Product Type:</label>
    <select name='create_product_type' id='create_product_type' required>
        <option value='' disabled selected>Select Type</option>
        <option value='CARD'>Card</option>
        <option value='BOX'>Box</option>
    </select>

    <label for='create_product_set_id'>Set:</label>
    <select name='create_product_set_id' id='create_product_set_id' required>
        <option value='' disabled selected>Select Set</option>
        {{#each sets}}
        <option value='{{this.[Set ID]}}'>{{this.[Set ID]}} - {{this.[Name]}}</option>
        {{/each}}
    </select>

    <label for='create_product_name'>Name:</label>
    <input type='text' name='create_product_name' id='create_product_name' required />

    <label for='create_product_condition'>Card Condition (cards only):</label>
    <select name='create_product_condition' id='create_product_condition'>
        <option value=''>None</option>
        <option value='NM'>NM</option>
        <option value='LP'>LP</option>
        <option value='MP'>MP</option>
        <option value='HP'>HP</option>
        <option value='DMG'>DMG</option>
    </select>

    <label for='create_product_sku'>SKU (boxes only):</label>
    <input type='text' name='create_product_sku' id='create_product_sku' />

    <label for='create_product_price'>Price:</label>
    <input type='number' step='0.01' min='0' name='create_product_price' id='create_product_price' required />

    <label for='create_product_quantity'>Quantity:</label>
    <input type='number' min='0' name='create_product_quantity' id='create_product_quantity' required />

    <input type='submit' value='Add Product' />
</form>

<h2>Update a Product</h2>
<form class='cuForm' id='update_product_form' method='POST' action='/products/update'>
    <label for='update_product_id'>Product to Update:</label>
    <select name='update_product_id' id='update_product_id' required>
        <option value='' disabled selected>Select a Product</option>
        {{#each products}}
        <option value='{{this.[Product ID]}}'>
            {{this.[Product ID]}} - {{this.[Name]}}
        </option>
        {{/each}}
    </select>

    <label for='update_product_type'>Product Type:</label>
    <select name='update_product_type' id='update_product_type' required>
        <option value='' disabled selected>Select Type</option>
        <option value='CARD'>Card</option>
        <option value='BOX'>Box</option>
    </select>

    <label for='update_product_set_id'>Set:</label>
    <select name='update_product_set_id' id='update_product_set_id' required>
        <option value='' disabled selected>Select Set</option>
        {{#each sets}}
        <option value='{{this.[Set ID]}}'>{{this.[Set ID]}} - {{this.[Name]}}</option>
        {{/each}}
    </select>

    <label for='update_product_name'>Name:</label>
    <input type='text' name='update_product_name' id='update_product_name' required />

    <label for='update_product_condition'>Card Condition:</label>
    <select name='update_product_condition' id='update_product_condition'>
        <option value=''>None</option>
        <option value='NM'>NM</option>
        <option value='LP'>LP</option>
        <option value='MP'>MP</option>
        <option value='HP'>HP</option>
        <option value='DMG'>DMG</option>
    </select>

    <label for='update_product_sku'>SKU:</label>
    <input type='text' name='update_product_sku' id='update_product_sku' />

    <label for='update_product_price'>Price:</label>
    <input type='number' step='0.01' min='0' name='update_product_price' id='update_product_price' required />

    <label for='update_product_quantity'>Quantity:</label>
    <input type='number' min='0' name='update_product_quantity' id='update_product_quantity' required />

    <input type='submit' value='Update Product' />
</form>